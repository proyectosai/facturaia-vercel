{
  "name": "facturaia-app",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "demo:build": "node scripts/run-next-demo.mjs build",
    "demo:start": "node scripts/run-next-demo.mjs start",
    "build": "next build",
    "start": "next start",
    "doctor": "node scripts/facturaia-doctor.mjs",
    "lint": "eslint .",
    "typecheck": "node -e \"const fs=require('fs'); fs.rmSync('.next/types',{recursive:true,force:true,maxRetries:5,retryDelay:100});\" && next typegen && tsc --noEmit --incremental false",
    "e2e:local:server": "node scripts/start-local-e2e.mjs",
    "test:local-core": "vitest run tests/local-core.test.ts",
    "test:massive-local": "vitest run tests/local-core.test.ts tests/env.test.ts tests/local-auth-security.test.ts tests/local-audit.test.ts tests/backups-local.test.ts tests/local-billing-qa.test.ts tests/local-office-qa.test.ts tests/local-banking.test.ts tests/local-communications.test.ts tests/local-encryption.test.ts tests/document-study.test.ts tests/modules.test.ts",
    "test:e2e:local": "node tests/local-e2e.cjs",
    "test:quality": "npm run lint && npm run typecheck && npm test && npm run demo:build && npm run test:smoke",
    "test": "vitest run",
    "test:smoke": "node scripts/facturaia-smoke.mjs"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "imapflow": "^1.2.16",
    "lucide-react": "^0.577.0",
    "mailparser": "^3.9.4",
    "next": "^15.5.13",
    "nodemailer": "^8.0.3",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sql.js": "^1.4.10",
    "eslint": "^9",
    "eslint-config-next": "^15.5.13",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.0"
  }
}
